# Secrets — never commit
.env

# Personal financial data — never commit (real holdings/cost basis).
# A sanitized placeholder ships in the repo; edit your own copy locally
# or via the in-app Portfolio Editor.
Portfolio.md
external_holdings.json

# Python
__pycache__/
*.pyc

# Generated report output (grows continuously, not source code). Leading
# slash anchors this to the repo root — a bare "reports/" also matches
# backend/app/reports/, the actual source package, and silently excludes
# it from git (this happened; see git history).
/reports/

# v2 local state — watchlists, settings, run history (per-user, never source)
data_store/

# Frontend
node_modules/
frontend/dist/

# OS junk
.DS_Store
Thumbs.db

# Claude Code local/session-only state (not project tooling)
.claude/scheduled_tasks.lock
.claude/settings.local.json

# Personal continuation notes — local only, never publish
HANDOFF.md

# Runtime logs from scheduled scripts (digest, watcher)
scripts/*.log

# Personal notification/automation layer — local only, never in the public
# repo (see HANDOFF "Public-repo scope decision"). Restored from git history
# to run on this machine; kept untracked here.
backend/app/notify/
backend/app/scanner.py
backend/app/api/scanner.py
backend/app/skills/chokepoints.py
backend/app/digest.py
backend/app/watcher.py
backend/tests/test_scanner.py
backend/tests/test_telegram.py
