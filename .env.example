# Copy this file to .env and fill in the keys you want to use.
# Every key below is optional — the app launches and the GUI works with
# zero keys configured. What changes is what features are unlocked; see
# the table in README.md.

# AI agents (need at least one of these three to get AI-written reports)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Local LLM (free, runs on your own hardware) — any OpenAI-compatible server:
# Ollama default is http://127.0.0.1:11434/v1, LM Studio http://127.0.0.1:1234/v1.
# Then route any analyst role to a model id like "local/qwen3:14b" in Settings.
LOCAL_LLM_BASE_URL=
LOCAL_LLM_API_KEY=

# News & sentiment (free tiers available). Finnhub also powers the
# earnings/IPO calendars and the fundamentals fallback.
FINNHUB_API_KEY=
ALPHAVANTAGE_API_KEY=

# FRED — US macro data (rates, CPI, jobs) for the Macro analyst. Free key;
# works without one too (falls back to FRED's public CSV endpoint).
FRED_API_KEY=

# Moomoo has no API key — auth happens by logging into the OpenD gateway
# app with your moomoo account. Port 11111 is OpenD's default. Leave blank
# if you don't use moomoo; prices fall back to Yahoo Finance automatically.
MOOMOO_HOST=
MOOMOO_PORT=

# Interactive Brokers — no API key either; needs TWS or IB Gateway running
# locally with the API enabled. 7497 = TWS paper, 7496 = TWS live,
# 4002 = IB Gateway paper, 4001 = IB Gateway live. See README.md.
IBKR_HOST=
IBKR_PORT=
IBKR_CLIENT_ID=

# Tiger Brokers — needs a Tiger Open API account (separate signup, free)
# and an RSA keypair. See README.md's "Linking your broker" section.
TIGER_ID=
TIGER_ACCOUNT=
TIGER_PRIVATE_KEY_PATH=

# Telegram alerts (digest, holdings watcher, 24/7 scanner). Create a bot via
# @BotFather, add it to your group, set TELEGRAM_CHAT_ID to the group's id
# (negative number for supergroups). If the group has Topics enabled, map
# each alert source to a topic's thread id — send one message in each topic,
# then run `py -m app.notify.telegram` to read off chat_id/thread_id pairs.
# Leaving a TELEGRAM_TOPIC_* blank sends that source to the General topic.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TOPIC_PORTFOLIO=
TELEGRAM_TOPIC_OPPORTUNIST=

# Webull, Robinhood, and any other broker without a wired-up integration:
# see README.md's "Linking your broker" section for how to add them via
# external_holdings.json instead.
